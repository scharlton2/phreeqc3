	DATABASE ../database/Amm.dat
	SELECTED_OUTPUT 101
	    file                 t2_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION_SPECIES
	SOLUTION 1
	Na 1e1
	 Cl 1e1
	REACTION
	Na2CO3 1
	 0.05
	REACTION_TEMPERATURE
	 0 200 in 9
	USER_GRAPH
	 10 graph_x tc 
	 20 graph_y mol("NaCO3-")
	30 graph_sy act("HCO3-")
	END
