	20 dim d(9)
	30 for i = 1 to step_no : read d(i) : d(i) = 1e-3 * d(i) : next i
	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then F = tot("F") : Vmol = (1e3 + F * 41.9882) / (F * rho) - 1e3 / (F * get(10))
	52 if step_no > 1 then         VmolMaj = (1e3 + F * 41.9882) / (F * (get(10) + d(step_no))) - 1e3 / (F * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - VmolMaj
	70 put(abs(dif) + get(1), 1) : put(1 + get(2), 2)
	100 if step_no = 1 then goto 150
	110 plot_xy F^0.5, VmolMaj, symbol = Plus, line_w = 0, color = Yellow
	120 plot_xy F^0.5, Vmol, symbol = None, color = Yellow
	150 end
	END
