	USE solution 1
	REACTION_TEMPERATURE
	 25.050000
	REACTION_PRESSURE
	 98.700000
	REACTION
	 NaF 1
	0 0.100100 0.100100 0.249800 0.249800 0.499600 0.499600 0.899400 0.899400 
	USER_GRAPH
	 -headings 25.oC-99.atm
	-axis_scale y_axis -150 15
	 -axis_titles "NaF / (mol/kg H2O)^0.5" "NaF molar volume / (cm3/mol)"
	10 data 0, 4.300000, 4.340000, 10.760000, 10.770000, 21.030000, 21.070000, 36.670000, 36.670000, 
	20 dim d(9)
	30 for i = 1 to step_no : read d(i) : d(i) = 1e-3 * d(i) : next i
	40 if step_no = 1 then put(rho, 10) : put(0, 1) : put(0, 2) 
	50 if step_no > 1 then F = tot("F") : Vmol = (1e3 + F * 41.9882) / (F * rho) - 1e3 / (F * get(10))
	52 if step_no > 1 then         VmolMaj = (1e3 + F * 41.9882) / (F * (get(10) + d(step_no))) - 1e3 / (F * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - VmolMaj
	70 put(abs(dif) + get(1), 1) : put(1 + get(2), 2)
	100 if step_no = 1 then goto 150
	110 plot_xy F^0.5, VmolMaj, symbol = Square, line_w = 0, color = Red
	120 plot_xy F^0.5, Vmol, symbol = None, color = Red
	150 end
	END
