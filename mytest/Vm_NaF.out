	USE solution 1
	REACTION_TEMPERATURE
	 96.250000
	REACTION_PRESSURE
	 300.048000
	REACTION
	 NaF 1
	0 0.092900 0.092900 0.246100 0.246100 0.498800 0.498800 0.857500 0.857500 
	USER_GRAPH
	 -headings 96.oC-300.atm
	10 data 0, 4.120000, 4.100000, 10.200000, 10.170000, 16.930000, 16.910000, 25.830000, 25.800000, 
	20 dim d(9)
	30 for i = 1 to step_no : read d(i) : d(i) = 1e-3 * d(i) : next i
	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then F = tot("F") : Vmol = (1e3 + F * 41.9882) / (F * rho) - 1e3 / (F * get(10))
	52 if step_no > 1 then         VmolMaj = (1e3 + F * 41.9882) / (F * (get(10) + d(step_no))) - 1e3 / (F * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - VmolMaj
	70 put(abs(dif) + get(1), 1) : put(1 + get(2), 2)
	100 if step_no = 1 then goto 150
	110 plot_xy F^0.5, VmolMaj, symbol = Circle, line_w = 0, color = Orange
	120 plot_xy F^0.5, Vmol, symbol = None, color = Orange
	150 end
	END
