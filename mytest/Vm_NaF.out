	USER_GRAPH
	 -headings 25.oC-1.atm
	 -axis_titles "NaF / (mol/kg H2O)" "NaF molar volume / (cm3/mol)"
	10 data 0, -2.508000, -2.408000, -2.360000, -2.441000, -2.174000, -2.061000, -2.038000, -1.963000, -1.805000, -2.042000, -1.741000, -1.679000, -1.745000, -1.564000, -1.641000, -1.557000, -1.641000, -1.456000, -1.565000, -1.447000, -1.388000, -1.311000, -1.263000, -1.285000, -1.222000, -1.234000, -1.043000, -1.075000, -1.115000, -0.877000, -0.972000, -0.845000, -0.926000, -0.865000, -0.802000, -0.669000, -0.649000, -0.754000, -0.693000, -0.621000, -0.635000, -0.577000, -0.579000, -0.463000, -0.510000, -0.521000, -0.467000, -0.406000, -0.321000, -0.347000, -0.295000, -0.241000, -0.190000, -0.118000, 
	20 dim d(55)
	30 for i = 1 to step_no : read d(i) : next i
	40 if step_no = 1 then put(rho, 10) : if tc = 0 then put(0, 1) : put(0, 2)
	50 if step_no > 1 then F = tot("F") : Vmol = (1e3 + F * 41.9882) / (F * rho) - 1e3 / (F * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	70 put(abs(dif) + get(1), 1) : put(1 + get(2), 2)
	100 if step_no = 1 then goto 150
	110 plot_xy F^0.5, d(step_no), symbol = XCross, line_w = 0, color = Black
	120 plot_xy F^0.5, Vmol, symbol = None, color = Black
	130 if step_no = 55 then print 'Laliberte, 25C, AAD ' + str_f$(get(1) / get(2), 0, 3) + ' cm3/mol'
	150 end
	END
