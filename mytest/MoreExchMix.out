	database ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 MoreExchMix_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	EXCHANGE_SPECIES
	Fe+2 + Cl- + X- = FeClX
	 log_k 1
	SURFACE_MASTER_SPECIES
	Su Su-
	SURFACE_SPECIES
	Su- = Su-
	SOLUTION 1
	 Cl 1
	 pH 7 charge
	 Fe(+2) 0.1
	 redox 
	EQUILIBRIUM_PHASES 1
	 Calcite 0
	SAVE solution 1
	END
