	SELECTED_OUTPUT 101
	    file                 solid_solution_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	PHASES
		Magnesite
		MgCO3 = CO3-2 + Mg+2
	        log_k           -10.480
	SOLUTION 1
		units umol/kgw
		pH 7.0
		Ca	10
		Mg	10
		C	40
	SOLID_SOLUTIONS	1
		Ca(x)Mg(1-x)CO3	
			component	Calcite		0 #1.0
			component	Magnesite	0 #0.03
	END
