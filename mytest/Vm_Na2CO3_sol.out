	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("C"), d(step_no), line_w = 0, color = Black
	80 plot_xy tot("C"), Vmol, symbol = None, color = Black
	90 end
