------------------------------------
Reading input data for simulation 2.
------------------------------------

	TRANSPORT
	 cells 10
	 length 1e-9
	 shifts 1 0
	 bcond 1 2
	 timest 5e-10
	 punch_frequency 1
	 multi_d true 1e-9 1 0 1
	SELECTED_OUTPUT
WARNING: Cell-lengths were read for 1 cells. Last value is used till cell 10.
WARNING: No dispersivities were read; disp = 0 assumed.
WARNING: No porosities were read; used the value 1.00e+00 from -multi_D.
	 file debye1.sel
	 reset false
	USER_PUNCH
	 heading dist H2O_aq H2O_edl H2O_tot Na Cl pH mass_Na mass_Cl
	 start
	 1 if step_no = 0 then goto 80
	 10 punch dist, tot("water"), edl("water"), tot("water") + edl("water"), tot("Na")*1e3, tot("Cl")*1e3, -la("H+")
	 20 if cell_no = 1 then put(0, 1)
	 30 if cell_no = 1 then put(0, 2)
	 40 put(sys("Na") + get(1), 1)
	 50 put(sys("Cl") + get(2), 2)
	 60 if cell_no = 10 then punch get(1) * 1e3
	 70 if cell_no = 10 then punch get(2) * 1e3
	 80 end
	 end
	END
