	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 debye1_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 0
	 Na 100
	 Cl 100 charge
	SOLUTION 1-10
	 Ca 0.1
	 C(4) 1 charge
	 water 1
	SURFACE_MASTER_SPECIES
	 Su Su-
	SURFACE_SPECIES
	 Su- = Su-
	 log_k 0
	END
