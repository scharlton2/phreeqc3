	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 phi_Duan_PR_EQ_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1
	SELECTED_OUTPUT
	 reset false
	 file phi_Duan_PR_EQ.sel
	USER_PUNCH
	  1 sc$ = chr$(59)
	 10 for i = 1.1 to 520 step 20
	 20   punch 'SOLUTION 1' + sc$ + '-pressure ' + str$(i) + sc$ + ' -temp 25' + EOL$ + 'EQUILIBRIUM_PHASES' +              sc$ + ' CO2(g) ' + str$(log10(i)) + EOL$ + 'END' + EOL$
	 30 next i
	END
