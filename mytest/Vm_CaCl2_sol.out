	50 if step_no > 1 then Vmol = (1e3 + tot("Ca") * 110.986) / (tot("Ca") * rho) - 1e3 / (tot("Ca") * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("Ca"), d(step_no), line_w = 0, color = Green #aph_x tot("Ca") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Ca"), Vmol, symbol = None, color = Green
	90 end
	END
