	70 plot_xy tot("Ca"), d(step_no), line_w = 0, color = Blue #aph_x tot("Ca") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Ca"), Vmol, symbol = None, color = Blue #step_no = 6 then put(step_no + get(1), 1)
	90 end
