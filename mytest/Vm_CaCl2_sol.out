	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("Ca"), d(step_no), line_w = 0, color = Black #aph_x tot("Ca") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Ca"), Vmol, symbol = None, color = Black #step_no = 26 then put(step_no + get(1), 1)
	90 end
	END
