	USE solution 1
	REACTION_TEMPERATURE
	 15.000000
	REACTION_PRESSURE
	 0.000000
	REACTION
	 CaCl2 1
	0 0.050000 0.100000 0.500000 1.000000 2.000000 3.000000 4.000000 6.000000
	USER_GRAPH
	 -headings 15.oC
	-axis_titles "CaCl2 / (mol/kg H2O)" "CaCl2 molar volume / (cm3/mol)"
	10 data 0, 18.829589, 18.946477, 20.954920, 22.731945, 25.408129, 27.642932, 29.475311, 32.659160,
	20 dim d(9)
	30 read d(1), d(2), d(3), d(4), d(5), d(6), d(7), d(8), d(9),
	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then Vmol = (1e3 + tot("Ca") * 110.986) / (tot("Ca") * rho) - 1e3 / (tot("Ca") * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("Ca"), d(step_no), line_w = 0, color = Yellow #aph_x tot("Ca") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Ca"), Vmol, symbol = None, color = Yellow #step_no = 264 then put(step_no + get(1), 1)
	90 end
	END
