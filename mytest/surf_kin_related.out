	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 surf_kin_related_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	KNOBS
		convergence_tolerance	1e-12
	RATES
	Pyrolusite
		start
	20      rem   1 hour half life
	40	moles = log(0.5) / 3600 * m * time
	50      if (moles > m) then moles = m
	60      rem print -moles
	200	save -moles
		end
	SOLUTION 1
		pH	7.0
		pe	8.0
		temp	20.0
		Ca	4.5
		Cl	9.0	charge
	SOLUTION 0 # FeCl2 injected solution
		pH	6.0
		pe	0.0
		temp	20.0
		Fe	15.5   # Analyzed: 14.55 
		Cl	31.	charge
		Mn	1e-8
		Al	1.e-8
	SURFACE 1
		Hfo_wOH    pyrolusite  		kine	0.1
		Hfo_sOH    pyrolusite  		kine	.01	500
	KINETICS 1
		Pyrolusite
			formula MnO2H2O 1.0 NaF 1.0
			m	1
		steps	3600
		step_divide	100
	USE solution 0
	END
