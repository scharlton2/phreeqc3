	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1 pure water
	pressure 863
	EQUILIBRIUM_PHASES
	CH4(g) 3 0.434
	SAVE solution 1
	END
