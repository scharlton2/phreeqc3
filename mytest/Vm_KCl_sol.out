	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then Vmol = (1e3 + tot("Cl") * 74.555) / (tot("Cl") * rho) - 1e3 / (tot("Cl") * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("Cl"), d(step_no), line_w = 0, color = Orange #aph_x tot("Cl") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Cl"), Vmol, symbol = None, color = Orange #step_no = 6 then put(step_no + get(1), 1)
	90 end
	END
