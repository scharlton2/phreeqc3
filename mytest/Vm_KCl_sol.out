	0 0.040000 0.060040 0.090000 0.100010 0.120060 0.160000 0.199980 0.250000 0.250170 0.350020 0.400000 0.452530 0.499660 0.499920 0.700000 0.936920 1.000000 1.396060 1.917390 2.394920 2.961220 3.446570 4.059680
	USER_GRAPH
	 -headings 5.oC
	-axis_titles "KCl / (mol/kg H2O)" "KCl molar volume / (cm3/mol)"
	10 data 0, 25.349828, 24.970000, 25.373436, 25.610000, 25.300000, 25.565970, 25.650000, 25.697588, 25.720000, 26.134000, 25.989084, 26.058476, 26.058476, 26.058476, 26.484755, 26.882850, 26.929242, 27.471998, 28.060749, 28.509081, 28.972534, 29.330194, 29.723543,
	20 dim d(24)
	30 read d(1), d(2), d(3), d(4), d(5), d(6), d(7), d(8), d(9), d(10), d(11), d(12), d(13), d(14), d(15), d(16), d(17), d(18), d(19), d(20), d(21), d(22), d(23), d(24),
	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then Vmol = (1e3 + tot("Cl") * 74.555) / (tot("Cl") * rho) - 1e3 / (tot("Cl") * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - d(step_no)
	62 if step_no = 1 then goto 90
	70 plot_xy tot("Cl"), d(step_no), line_w = 0, color = Yellow #aph_x tot("Cl") # dif, str$(tc), str$(pressure), str$(step_no + get(1))
	80 plot_xy tot("Cl"), Vmol, symbol = None, color = Yellow #step_no = 264 then put(step_no + get(1), 1)
	90 end
	END
