	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 Na2SO4_phr_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION_SPECIES
	SO4-2 = SO4-2
		gamma	     2.6878744E+00    -1.9968622E-01
	Na+ + SO4-2 = NaSO4-
	 log_k -1e5
	H2O + 0.01e- = H2O-0.01
	log_k -9
	SOLUTION 1
	PHASES
	Mirabilite
		Na2SO4:10H2O  =  SO4-2 + 2 Na+ + 10 H2O
		log_k	   -1.214
		analytical_expression     -3862.234   -1.19856    93713.54    1577.756    0.0
		Vm 216
	Thenardite
		Na2SO4 = 2 Na+ + SO4-2
		log_k -0.35
	 analytical_expression  7.9206627e2  3.6570899e-1  -1.9344429e4  -3.3198923e2  0  -1.6913933e-4 
	 Vm 52.9
	EQUILIBRIUM_PHASES 1
	 Mirabilite 0 12
	 Thenardite 0 0
	REACTION_TEMPERATURE 1
	 0 35 in 8
	USER_GRAPH 1
	-chart_title "Mirabilite/Thenardite solubility"
	-axis_titles "mol Na2SO4 / kgw" "temperature / oC"
	-plot_csv_file Na2SO4.csv
	70 plot_xy tot("S"), tc, symbol_size = 0, color = Red
	-end
	PRINT
	 status false
	SAVE solution 1
	END
