	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 run_cells_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	RATES
	KBr
	10 k = 1  # 1/s
	20 rate = k * TOT("Br")
	30 SAVE rate*TIME
	END
