	USER_GRAPH
	 -headings 25.oC-296.atm
	10 data 0, 4.770000, 4.800000, 11.680000, 11.700000, 23.650000, 23.670000, 45.980000, 45.890000, 128.520000, 128.480000, 
	20 dim d(11)
	30 for i = 1 to step_no : read d(i) : d(i) = 1e-3 * d(i) : next i
	40 if step_no = 1 then put(rho, 10)
	50 if step_no > 1 then F = tot("F") : Vmol = (1e3 + F * 58.1004) / (F * rho) - 1e3 / (F * get(10))
	52 if step_no > 1 then         VmolMaj = (1e3 + F * 58.1004) / (F * (get(10) + d(step_no))) - 1e3 / (F * get(10))
	60 if step_no = 1 then dif = 0 else dif = Vmol - VmolMaj
	70 put(abs(dif) + get(1), 1) : put(1 + get(2), 2)
	100 if step_no = 1 then goto 150
	110 plot_xy F^0.5, VmolMaj, symbol = Diamond, line_w = 0, color = Green
	120 plot_xy F^0.5, Vmol, symbol = None, color = Green
	150 end
	END
