------------------------------------
Reading input data for simulation 1.
------------------------------------

	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 N2_ideal_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	PHASES
	N2(g)
	N2 = N2
	log_k		 -3.1864
	analytical_expression -58.453 1.81800E-03  3199  17.909 -27460
	t_c 150
	 p_c 3000 # these parameters give near ideal behavior
	SOLUTION 1
	 temp 150 # the ideal one (below) does not converge with temp 200
	INCREMENTAL_REACTIONS
	GAS_PHASE 1
	 fixed_volume
	 N2(g) 0
	REACTION 1
	 N2 1
	 27 in 20
	 USER_GRAPH
	 -headings Vm N2-ideal/critical
	 -axis_titles "Gas Molar Volume / (L/mole)" "Gas Pressure / atm"
	 10 graph_x gas_vm
	 20 graph_y gas_p
	END
