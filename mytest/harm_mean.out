	DATABASE ../database/wateq4f.dat
	SELECTED_OUTPUT 101
	    file                 harm_mean_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION_MASTER_SPECIES # define the tracers...
	Hto Hto 0 Hto 20
	Hdo Hdo 0 Hdo 21
	Nat Nat+ 0 Nat 22
	I I- 0 I 126.9
	Cl_tr Cl_tr- 0 Cl_tr 36.45
	Cs     Cs+     0 Cs 132.9
	SOLUTION_SPECIES
	Hto = Hto
	Hdo = Hdo
	Nat+ = Nat+
	I- = I-
	Cl_tr- = Cl_tr-
	PHASES
	Hto
		Hto = Hto
		log_k  -13.
	Hdo
		Hdo = Hdo
		log_k  -13.
	I
		NaI = I- + Na+
		log_k  -13.
	Nat
		NatCl = Nat+ + Cl-
		log_k  -13.
	END
