	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 ss_r_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	KNOBS
	 step_size 2
	 pe_step_size 2
	 iterations 300
	 diagonal_scale true
	RATES
	 CO2_escape
	 10 P_CO2 = SI("CO2(g)")
	 12 if P_CO2 < -3.4999 then goto 30
	 20 rate = (P_CO2 + 3.5)/3600/5e3
	 30 save rate * time
	SOLUTION 1-11
	 pH 7.0 CO2(g) -3.5
	 pe 14 O2(g) -1.0
	 Ca 1.5 Calcite
	 Zn 1.5e-9
	 C(4) 1.0 charge
	SOLUTION 0
	pH 7.0 Calcite 0.0
	pe 14 O2(g) -1.0
	Ca 1.5
	Zn 1.5e-3
	C(4) 1.0 charge
	END
