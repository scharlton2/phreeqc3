	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 P_Vm_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION_SPECIES
	HS- + H+ = H2S
		log_k	6.994
		delta_h -5.30	kcal
		analytical_expression  -11.17   0.02386  3279.0
		dw	 2.1e-9
		vm  7.81  2.96  -0.46 # supcrit
	2 NO3- + 12 H+ + 10 e- = N2 + 6 H2O
		log_k	207.08
		delta_h -312.130	kcal
		dw	 1.96e-9
		vm 7 # Pray et al., 1952, IEC 44. 1146
	CO3-2 + 2 H+ = CO2 + H2O
		log_k	   16.6767
		delta_h	 -5.738  kcal
		analytical_expression    464.1925    0.09344813  -26986.16	-165.75951   2248628.9
		dw	 1.92e-9
		vm   12.84 -24.3 11.1 1.52  # supcrt modified
	CO3-2 + 10 H+ + 8 e- = CH4 + 3 H2O
		log_k	41.071
		delta_h -61.039 kcal
		dw	 1.85e-9
		vm 7.7
	SOLUTION 1#; -temp 200
	INCREMENTAL_REACTIONS
	GAS_PHASE 1
	 fixed_volume
	 CO2(g) 0
	 H2O(g) 0
	REACTION 1
	 CO2 1
	 27 in 20
	 USER_GRAPH
	 -headings Vm CO2
	 -axis_titles "Gas Molar Volume / (L/mole)" "Gas Pressure / atm"
	 -axis_scale x_axis 0 1
	 -axis_scale y_axis 0 500
	 10 graph_x gas_vm
	 20 graph_y gas_p
	END
