------------------------------------
Reading input data for simulation 1.
------------------------------------

	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 gypsum_P_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1
	pH 7 charge
	temp 62
	EQUILIBRIUM_PHASES
	Gypsum
	Anhydrite
	REACTION_PRESSURE
	1 1000 in 10
	USER_GRAPH
	 -headings p Ca SI_Anhydrite SI_Gypsum
	 -axis_titles "Pressure / atm" "mol/kgw" SI
	 -axis_scale sy_axis -0.1 0.04
	 10 graph_x pressure
	 20 graph_y tot("Ca")
	 30 graph_sy SI("Anhydrite"), SI("Gypsum")
	 -end
	USER_GRAPH 2 apparent log_k of CaSO4 complex
	 -headings p
	 -axis_titles "Pressure / atm" "log10 (K)"
	 -axis_scale y_axis 2 2.5
	 10 graph_x pressure
	 20 graph_y log10(act("CaSO4") / (act("Ca+2") * act("SO4-2")))
	END
