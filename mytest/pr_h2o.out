	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 pr_h2o_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	KNOBS
	step_size 2
	pe_step_size 2
	iterations 1000
	PHASES
	H2O(g)
		H2O = H2O
		log_k  1.506
	 delta_h -44.03 kJ
		t_c  647.3
		p_c  217.60
		omega 0.344
		analytical_expression   -16.5066 -2.0013E-3  2710.7  3.7646  0 2.24E-6
	solution
	temp 30
	pH  7 charge
	Na 1.562e0
	Cl 1.562e0
	END
