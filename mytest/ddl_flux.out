	DATABASE ../database/wateq4f.dat
	SELECTED_OUTPUT 101
	    file                 ddl_flux_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION_MASTER_SPECIES
	Hto     Hto             0.0     1       1
	Na_tr   Na_tr+          0.0     1       1
	Cl_tr   Cl_tr-          0.0     1       1
	Sr_tr   Sr_tr+2         0.0     1       1
	SOLUTION_SPECIES
	Hto = Hto
	 log_k 0
	 gamma 1e6 0
	 erm_ddl 1#-dw 2.236e-9
	Na_tr+ = Na_tr+
	 log_k 0
	 gamma 1e6 0
	Cl_tr- = Cl_tr-
	 log_k 0
	 gamma 1e6 0
	Sr_tr+2 = Sr_tr+2
	 log_k 0
	 gamma 1e6 0
	SURFACE_MASTER_SPECIES
	 Su Su-
	 Sua Sua+
	SURFACE_SPECIES
	 Su- = Su-
	 log_k 0
	 Sua+ = Sua+
	 log_k 0
	END
