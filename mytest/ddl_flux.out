------------------------------------
Reading input data for simulation 5.
------------------------------------

	SELECTED_OUTPUT
	 file ddl_flux.prn
	 reset false
	USER_PUNCH
	 heading days J_hto J_sr J_na J_cl EB #A_hto A_Sr
	 start
	  1 t$ = chr$(9) + '  '
	  2 if step_no = 0 then punch eol$ + '     analyt' + t$ + trim(str$(6.9396e-7)) + t$ + trim(str$(6.9396e-7 * 51.474)) + t$ + trim(str$(6.9396e-7 * 5.5484)) + t$ + trim(str$(6.9396e-7 * 0.54952)) + eol$ : goto 80
	  10 punch total_time / (24 * 3600)
	  12 if step_no = 0 then goto 80
	  20 A_hto = equi("A_hto")
	  30 A_sr = equi("A_sr")
	  32 A_na = equi("A_na")
	  34 A_cl = equi("A_cl")
	  40 J_hto = (A_hto - get(1))
	  50 J_sr = (A_sr - get(2)) 
	  52 J_na = (A_na - get(3))
	  54 J_cl = (A_cl - get(4))
	  60 punch J_hto, J_sr, J_na, J_cl, percent_error
	  80 put(A_hto, 1)
	  90 put(A_sr, 2)
	  92 put(A_na, 3)
	  94 put(A_cl, 4)
	 end
	TRANSPORT
	 shifts 11
	 flow_direction diff
	 cells 6
	 bcond 1 2
	 lengths 6*1
	 timest 5e9  1
	 multi_d true 2e-09 0.3 0 0.8
	 punch_cells 6
	END
