	EXCHANGE_SPECIES
	SURFACE_MASTER_SPECIES
	SURFACE_SPECIES
	MEAN_GAMMAS
	RATES
	END
------------------------------------
Reading input data for simulation 1.
------------------------------------

	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 krest_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SURFACE_MASTER_SPECIES
		Solid	Solid
	SURFACE_SPECIES
		Solid = Solid
		log_k 0
		Solid + [224Ra] = Solid[224Ra]
		log_k	-98.7	# log(Kd) - 100
	SOLUTION_MASTER_SPECIES
		[224Ra]	[224Ra]	0	224	224
	SOLUTION_SPECIES
		[224Ra] = [224Ra]
		log_k	0.0
	RATES
		Add_Ra
	start
	10 rate = 1 / (24*3600)   # 1/day
	20 moles = parm(1) * rate * TIME
	30 save moles
	end
		Decay_Ra
	start
	10 k = .189 / (24*3600)  # 3.66 day half life
	20 total_224Ra = TOT("[224Ra]") + MOL("Solid[224Ra]")
	30 rate = -k*total_224Ra
	40 moles = rate*TIME
	50 save moles
	end
	END
------------------
End of simulation.
------------------

