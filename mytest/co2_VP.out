------------------------------------
Reading input data for simulation 1.
------------------------------------

	database ../database/phreeqc.dat # contains Dw's since version 2.17
	SELECTED_OUTPUT 101
	    file                 co2_VP_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1
	temp 25 # 40.09
	REACTION 1
	CO2 1
	 0.1 10*0.4 12*2
	INCREMENTAL_REACTIONS true
	GAS_PHASE 1
	fixed_volume
	 CO2(g) 20
	USER_GRAPH
	-headings Vm
	-plot_csv_file co2_VP.dat
	-connect_simulations false
	-axis_scale x_axis 0 0.5 #0.2
	-axis_scale y_axis 0 500 #100
	-axis_titles "molar volume / (L/mol)" "Gas pressure / atm"
	60 graph_x 1 / gas("CO2(g)")
	70 graph_y  gas_p #* pr_phi("CO2(g)")
	END
