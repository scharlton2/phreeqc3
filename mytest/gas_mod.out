	USE solution 1
	GAS_PHASE 1
	fixed_volume 
	volume 1e-6 
	CO2(g) 0 
	SAVE gas_phase 1
	SELECTED_OUTPUT
	 reset false
	 file gas_mod.inp
	 high_precision true
	USER_PUNCH 
	2 sc$ = CHR$(59) 
	10 punch 'GAS_PHASE_MODIFY 1' + sc$ + ' -volume 1' + EOL$ 
	20 punch '-comp CO2(g)' + EOL$ 
	30 punch '-moles '+ STR$(1e6 * GAS("CO2(g)")) + EOL$ 
	END 
