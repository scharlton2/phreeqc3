	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	PHASES 
	CO2(g) 
	CO2 = CO2 
	analytical_expression 108.3865 0.01985076 -6919.53 -40.45154 669365.0 
	t_c 304.2 # critical T, K 
	p_c 72.80 # critical P, atm 
	omega 0.225 # Pitzer acentric factor
	SOLUTION 1
	pH 7 charge 
	C(4) 1 CO2(g) 1.0 
	pressure 10 
	END
