	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	USER_PRINT
	10 print Description, -la("H+"),  tot("Ca")
	SOLUTION_SPREAD
	Description		 pH		 Ca
