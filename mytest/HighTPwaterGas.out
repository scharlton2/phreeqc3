	-headings RXN Gas_volume pH
	-axis_titles "CO2 addition, mol" "Gas volume, L" "pH"
	10 GRAPH_X RXN
	20 GRAPH_Y GAS_VM * GAS("CO2(g)")
	30 GRAPH_SY -LA("H+")
	END 
