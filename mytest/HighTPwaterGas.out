	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 HighTPwaterGas_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1
	    temp      65
	    pH        7  charge
	    pe        4
	    redox     pe
	    units     mmol/kgw
	    density   1
	    Cl        10
	    Na        10
	    water    1 # kg
	END
