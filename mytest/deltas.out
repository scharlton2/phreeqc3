	10 PRINT "Delta Dolomite: ", EQUI_DELTA("Dolomite")
	20 PRINT "Delta Calcite:  ", KIN_DELTA("Calcite")
	SELECTED_OUTPUT
	file deltas.pun
	reset false
	kinetic_reactants calcite
	equilibrium_phases dolomite
	END
