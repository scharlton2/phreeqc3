------------------------------------
Reading input data for simulation 1.
------------------------------------

	DATABASE ../database/phreeqc.dat
	SELECTED_OUTPUT 101
	    file                 Anhy_NaCl_T&P_101.sel
	USER_PUNCH 101
	    headings Mu SC
	    start
	10 PUNCH STR_F$(MU, 20, 12)
	20 PUNCH STR_F$(SC, 20, 10)
	    end
	SOLUTION 1
	pH 7 charge
	temp 100
	EQUILIBRIUM_PHASES 1
	Anhydrite
	REACTION 1
	 NaCl 1
	 0 1e-5 5*0.02 0.1 12*0.2 6*1
	INCREMENTAL_REACTIONS true
	USER_GRAPH
	-chart_title "Anhydrite solubility"
	-axis_titles "NaCl / (mol/kgw)" "CaSO4 / (mol/kgw)"
	-axis_scale x_axis 0 8.5
	-axis_scale y_axis 0 0.05
	-connect_simulations false
	10 plot_xy tot("Na"), tot("Ca"), symbol = None
	END
